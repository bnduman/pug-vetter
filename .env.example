# Copy this file to ".env" and fill in your Warcraft Logs API credentials.
# Create a client at: https://www.warcraftlogs.com/api/clients/

WCL_CLIENT_ID=your_client_id_here
WCL_CLIENT_SECRET=your_client_secret_here

# Default realm/region used when the search box leaves them blank.
DEFAULT_REGION=US
DEFAULT_REALM=

# How long (seconds) to cache a character lookup, to spare the WCL rate limit.
CACHE_TTL_SECONDS=600

# Advanced: override only if you know what you're doing.
# WCL_API_URL=https://classic.warcraftlogs.com/api/v2/client
# WCL_TOKEN_URL=https://www.warcraftlogs.com/oauth/token
